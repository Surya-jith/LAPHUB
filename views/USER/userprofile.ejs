                </div>
                <button class="btn-update-photo">Update photo</button>
              </div>

              <!-- Fields column -->
              <div class="col">
                <div class="row g-3 mb-3">
                  <div class="col-md-6">
                    <label class="form-label-sm">Name</label>
                    <input type="text" class="form-ctrl" value="Surya Jith"/>
                  </div>
                  <div class="col-md-6">
                    <label class="form-label-sm">Email</label>
                    <input type="email" class="form-ctrl" value="Suryajith@gmail.com"/>
                  </div>
                </div>
                <div class="row g-3">
                  <div class="col-md-6">
                    <label class="form-label-sm">Phone Number</label>
                    <input type="tel" class="form-ctrl" value="+91 000000000"/>
                  </div>
                  <div class="col-md-6 d-flex align-items-end justify-content-end">
                    <button class="btn-save">Save Changes</button>
                  </div>
                </div>
              </div>

            </div>

            <!-- Referral code -->
            <div class="referral-box">
              <p>Your referral code</p>
              <span class="referral-code">s45af4lm@LAP</span>
            </div>

          </div>
        </div>

        <!-- ── CHANGE PASSWORD PANEL ── -->
        <div class="panel-card">
          <div class="panel-header">Change Password</div>
          <div class="panel-body">

            <div class="mb-3">
              <label class="form-label-sm">Current Password</label>
              <div class="pw-input-wrap">
                <input type="password" class="form-ctrl" id="curPass" placeholder=""/>
                <button class="pw-eye" type="button" onclick="togglePw('curPass','eyeCur')">
                  <i class="fa-regular fa-eye" id="eyeCur"></i>
                </button>
              </div>
            </div>

            <div class="mb-3">
              <label class="form-label-sm">New Password</label>
              <div class="pw-input-wrap">
                <input type="password" class="form-ctrl" id="newPass" placeholder="8+ characters"/>
                <button class="pw-eye" type="button" onclick="togglePw('newPass','eyeNew')">
                  <i class="fa-regular fa-eye" id="eyeNew"></i>
                </button>
              </div>
            </div>

            <div class="mb-3">
              <label class="form-label-sm">Confirm Password</label>
              <div class="pw-input-wrap">
                <input type="password" class="form-ctrl" id="confPass" placeholder="8+ characters"/>
                <button class="pw-eye" type="button" onclick="togglePw('confPass','eyeConf')">
                  <i class="fa-regular fa-eye" id="eyeConf"></i>
                </button>
              </div>
            </div>

            <button class="btn-change-pw" type="button">Change Password</button>

          </div>
        </div>

      </div><!-- /col -->
    </div><!-- /row -->
  </div><!-- /container -->
</div>

<!-- ── FOOTER ── -->
<footer>
