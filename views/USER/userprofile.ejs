<!-- ── MAIN ── -->
<div class="main-content">
  <div class="container">
    <div class="row g-4">

      <!-- SIDEBAR -->
      <div class="col-lg-3 col-md-4">
        <div class="sidebar">
          <a class="sidebar-item" href="#">
            <i class="fa-solid fa-table-cells-large"></i> Dashboard
