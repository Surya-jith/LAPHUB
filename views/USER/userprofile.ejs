<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>LapHUB – Account Details</title>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/css/bootstrap.min.css" rel="stylesheet"/>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700;900&family=Barlow:wght@400;500;600;700&display=swap" rel="stylesheet"/>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: 'Barlow', sans-serif;
      background: #f0f2f5;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    /* ── NAVBAR ── */
    .navbar-top {
      background: #fff;
      padding: 10px 0;
      box-shadow: 0 1px 4px rgba(0,0,0,0.08);
    }
    .brand-box {
      background: #111;
      color: #fff;
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: 1rem;
      padding: 6px 12px;
      letter-spacing: 1px;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 6px;
    }
    .brand-box .brand-icon {
      width: 28px; height: 28px;
      border-radius: 50%;
      border: 2px solid #fff;
      display: flex; align-items: center; justify-content: center;
      font-size: .6rem;
    }
    .navbar-top .nav-link {
      color: #444;
      font-weight: 500;
      font-size: .95rem;
      padding: 6px 14px;
    }
    .navbar-top .nav-link:hover { color: #3a5bd9; }
    .navbar-icons { display: flex; align-items: center; gap: 16px; }
    .navbar-icons a { color: #555; font-size: 1.1rem; text-decoration: none; position: relative; }
    .navbar-icons a:hover { color: #3a5bd9; }
    .cart-badge {
      position: absolute;
      top: -6px; right: -8px;
      background: #3a5bd9;
      color: #fff;
      font-size: .6rem;
      font-weight: 700;
      width: 16px; height: 16px;
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
    }
    .navbar-username {
      font-size: .9rem;
      font-weight: 600;
      color: #222;
    }

    /* ── MAIN LAYOUT ── */
    .main-content {
      flex: 1;
      padding: 28px 0 60px;
    }

    /* ── SIDEBAR ── */
    .sidebar {
      background: #fff;
      border-radius: 8px;
      box-shadow: 0 1px 6px rgba(0,0,0,.06);
      overflow: hidden;
    }
    .sidebar-item {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 13px 20px;
      font-size: .9rem;
      color: #555;
      cursor: pointer;
      border: none;
      background: none;
      width: 100%;
      text-align: left;
      transition: background .15s, color .15s;
      text-decoration: none;
    }
    .sidebar-item:hover { background: #f0f4ff; color: #3a5bd9; }
    .sidebar-item.active {
      background: #3a5bd9;
      color: #fff;
      font-weight: 600;
    }
    .sidebar-item i { width: 18px; text-align: center; font-size: .95rem; }

    /* ── PANEL CARD ── */
    .panel-card {
      background: #fff;
      border-radius: 8px;
      box-shadow: 0 1px 6px rgba(0,0,0,.06);
      margin-bottom: 20px;
      overflow: hidden;
    }
    .panel-header {
      padding: 16px 24px;
      border-bottom: 1px solid #eee;
      font-size: .78rem;
      font-weight: 700;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      color: #444;
    }
    .panel-body { padding: 28px 24px; }

    /* Profile avatar */
    .avatar-wrap {
      position: relative;
      display: inline-block;
    }
    .avatar-circle {
      width: 110px; height: 110px;
      border-radius: 50%;
      background: #3c9e4e;
      display: flex; align-items: center; justify-content: center;
      overflow: hidden;
      /*
        ══════════════════════════════════════════
        IMAGE SLOT — replace with:
        background-image: url('your-avatar.jpg');
        background-size: cover;
        background-position: center;
        ══════════════════════════════════════════
      */
    }
    .avatar-circle i { font-size: 3.8rem; color: rgba(255,255,255,0.85); }
    /* Or drop an <img> tag inside .avatar-circle */

    .btn-update-photo {
      background: #3a5bd9;
      color: #fff;
      border: none;
      border-radius: 8px;
      padding: 10px 20px;
      font-size: .88rem;
      font-weight: 600;
      cursor: pointer;
      margin-top: 14px;
      transition: background .2s;
      display: block;
      text-align: center;
    }
    .btn-update-photo:hover { background: #2a4bc9; }

    /* Form inputs */
    .form-label-sm {
      font-size: .8rem;
      color: #666;
      font-weight: 500;
      margin-bottom: 5px;
      display: block;
    }
    .form-ctrl {
      width: 100%;
      border: 1px solid #dde;
      border-radius: 6px;
      padding: 10px 14px;
      font-size: .9rem;
      color: #222;
      outline: none;
      transition: border-color .2s, box-shadow .2s;
      background: #fff;
    }
    .form-ctrl:focus {
      border-color: #3a5bd9;
      box-shadow: 0 0 0 3px rgba(58,91,217,.12);
    }
    .form-ctrl::placeholder { color: #bbc; }

    /* Referral code box */
    .referral-box {
      text-align: center;
      margin-top: 24px;
    }
    .referral-box p {
      font-size: .9rem;
      font-weight: 600;
      color: #222;
      margin-bottom: 8px;
    }
    .referral-code {
      display: inline-block;
      background: #e8eaf0;
      border: 1px solid #ccd;
      border-radius: 6px;
      padding: 8px 22px;
      font-size: .92rem;
      font-weight: 600;
      color: #333;
      letter-spacing: 1px;
      font-family: monospace;
    }

    .btn-save {
      background: #3a5bd9;
      color: #fff;
      border: none;
      border-radius: 8px;
      padding: 11px 26px;
      font-size: .9rem;
      font-weight: 600;
      cursor: pointer;
      transition: background .2s;
      float: right;
    }
    .btn-save:hover { background: #2a4bc9; }

    /* Password fields */
    .pw-input-wrap {
      position: relative;
    }
    .pw-eye {
      position: absolute;
      right: 14px;
      top: 50%;
      transform: translateY(-50%);
      background: none;
      border: none;
      color: #999;
      font-size: .9rem;
      cursor: pointer;
      padding: 0;
    }
    .pw-eye:hover { color: #3a5bd9; }
    .pw-input-wrap .form-ctrl { padding-right: 40px; }

    .btn-change-pw {
      background: #3a5bd9;
      color: #fff;
      border: none;
      border-radius: 8px;
      padding: 11px 26px;
      font-size: .9rem;
      font-weight: 600;
      cursor: pointer;
      transition: background .2s;
      margin-top: 8px;
    }
    .btn-change-pw:hover { background: #2a4bc9; }

    /* ── FOOTER ── */
    footer {
      background: #111827;
      color: #ccc;
      padding: 55px 0 28px;
    }
    .footer-feedback {
      background: #1e2a3a;
      border-radius: 10px;
      padding: 26px 24px;
    }
    .footer-feedback .badge-fb {
      font-size: .65rem;
      color: #4a90d9;
      letter-spacing: 2px;
      text-transform: uppercase;
      font-weight: 700;
      display: block;
      margin-bottom: 10px;
    }
    .footer-feedback h4 {
      color: #aaa;
      font-size: 1rem;
      font-weight: 400;
      line-height: 1.5;
      margin-bottom: 16px;
    }
    .footer-feedback h4 strong { color: #fff; font-weight: 700; }
    .footer-input-wrap {
      position: relative;
      margin-bottom: 10px;
    }
    .footer-input-icon {
      position: absolute;
      left: 12px;
      top: 50%;
      transform: translateY(-50%);
      color: #557;
      font-size: .85rem;
    }
    .footer-input {
      width: 100%;
      background: transparent;
      border: 1px solid #334;
      border-radius: 6px;
      color: #ccc;
      padding: 10px 12px 10px 34px;
      font-size: .85rem;
      outline: none;
      transition: border-color .2s;
    }
    .footer-input::placeholder { color: #556; }
    .footer-input:focus { border-color: #4a90d9; }
    .btn-send {
      background: #4a90d9;
      color: #fff;
      border: none;
      padding: 10px 22px;
      border-radius: 6px;
      font-weight: 600;
      font-size: .88rem;
      cursor: pointer;
      transition: background .2s;
      margin-top: 6px;
    }
    .btn-send:hover { background: #3a7bc8; }
    .footer-privacy { font-size: .72rem; color: #445; margin-top: 10px; }

    footer h6 {
      color: #4a90d9;
      font-weight: 700;
      font-size: .72rem;
      letter-spacing: 2px;
      text-transform: uppercase;
      margin-bottom: 16px;
    }
    footer ul { list-style: none; padding: 0; }
    footer ul li { margin-bottom: 8px; }
    footer a { color: #ccc; text-decoration: none; font-size: .88rem; font-weight: 500; }
    footer a:hover { color: #fff; }
    .footer-contact p { font-size: .88rem; margin-bottom: 4px; color: #ccc; }
    .footer-contact a { color: #4a90d9; }

    .social-icons { display: flex; gap: 12px; margin-top: 20px; }
    .social-icons a {
      width: 38px; height: 38px;
      border-radius: 50%;
      background: #1e2a3a;
      display: flex; align-items: center; justify-content: center;
      color: #ccc;
      font-size: .9rem;
      transition: background .2s, color .2s;
    }
    .social-icons a:hover { background: #4a90d9; color: #fff; }

    .footer-bottom {
      border-top: 1px solid #1e2a3a;
      margin-top: 40px;
      padding-top: 16px;
      font-size: .75rem;
      color: #445;
      text-align: right;
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 767px) {
      .sidebar { margin-bottom: 20px; }
      .btn-save { float: none; width: 100%; margin-top: 12px; }
    }
  </style>
</head>
<body>

<!-- ── NAVBAR ── -->
<nav class="navbar-top">
  <div class="container d-flex align-items-center justify-content-between flex-wrap gap-2">
