<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>LapHUB – Account Edit</title>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/css/bootstrap.min.css" rel="stylesheet"/>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700;900&family=Barlow:wght@400;500;600;700&display=swap" rel="stylesheet"/>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: 'Barlow', sans-serif;
      background: #f0f2f5;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    /* ── NAVBAR ── */
    .navbar-top {
      background: #fff;
      padding: 10px 0;
      box-shadow: 0 1px 4px rgba(0,0,0,0.08);
    }
    .brand-box {
      background: #111;
      color: #fff;
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: 1rem;
      padding: 6px 12px;
      letter-spacing: 1px;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 6px;
    }
    .brand-box .brand-icon {
      width: 28px; height: 28px;
      border-radius: 50%;
      border: 2px solid #fff;
      display: flex; align-items: center; justify-content: center;
      font-size: .6rem;
    }
    .navbar-top .nav-link {
      color: #444;
      font-weight: 600;
      font-size: .95rem;
      padding: 6px 14px;
    }
    .navbar-top .nav-link:hover { color: #3a5bd9; }
    .nav-products { font-weight: 700; color: #111 !important; }
    .navbar-icons { display: flex; align-items: center; gap: 16px; }
    .navbar-icons a {
      color: #555; font-size: 1.1rem;
      text-decoration: none; position: relative;
    }
    .navbar-icons a:hover { color: #3a5bd9; }
    .cart-badge {
      position: absolute; top: -6px; right: -8px;
      background: #3a5bd9; color: #fff;
      font-size: .6rem; font-weight: 700;
      width: 16px; height: 16px; border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
    }
    .navbar-username { font-size: .9rem; font-weight: 600; color: #222; }

    /* ── MAIN ── */
    .main-content { flex: 1; padding: 28px 0 60px; }

    /* ── SIDEBAR ── */
    .sidebar {
      background: #fff;
      border-radius: 8px;
      box-shadow: 0 1px 6px rgba(0,0,0,.06);
      overflow: hidden;
    }
    .sidebar-item {
      display: flex; align-items: center; gap: 12px;
      padding: 13px 20px; font-size: .9rem; color: #555;
      cursor: pointer; border: none; background: none;
      width: 100%; text-align: left;
      transition: background .15s, color .15s;
      text-decoration: none;
    }
    .sidebar-item:hover { background: #f0f4ff; color: #3a5bd9; }
    .sidebar-item.active { background: #3a5bd9; color: #fff; font-weight: 600; }
    .sidebar-item i { width: 18px; text-align: center; font-size: .95rem; }

    /* ── PANEL CARD ── */
    .panel-card {
      background: #fff;
      border-radius: 8px;
      box-shadow: 0 1px 6px rgba(0,0,0,.06);
    }
    .panel-header {
      padding: 16px 24px;
      border-bottom: 1px solid #eee;
      font-size: .75rem;
      font-weight: 700;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      color: #444;
    }
    .panel-body { padding: 28px 24px 32px; }

    /* Avatar */
    .avatar-circle {
      width: 120px; height: 120px;
      border-radius: 50%;
      background: #3c9e4e;
      display: flex; align-items: center; justify-content: center;
      overflow: hidden;
      flex-shrink: 0;
      /*
        ══════════════════════════════════════════
        IMAGE SLOT — replace content with:
        <img src="your-avatar.jpg"
             style="width:100%;height:100%;object-fit:cover"/>
        ══════════════════════════════════════════
      */
    }
    .avatar-circle i { font-size: 4.2rem; color: rgba(255,255,255,0.85); }

    .btn-update-photo {
      background: #3a5bd9;
      color: #fff; border: none;
      border-radius: 8px;
      padding: 11px 22px;
      font-size: .9rem; font-weight: 600;
      cursor: pointer; margin-top: 16px;
      transition: background .2s;
      display: inline-block;
    }
    .btn-update-photo:hover { background: #2a4bc9; }

    /* Form */
    .form-label-sm {
      font-size: .8rem; color: #666;
      font-weight: 500; margin-bottom: 6px; display: block;
    }
    .form-ctrl {
      width: 100%;
      border: 1px solid #dde;
      border-radius: 6px;
      padding: 11px 14px;
      font-size: .92rem;
      color: #222; outline: none;
      background: #fff;
      transition: border-color .2s, box-shadow .2s;
    }
    .form-ctrl:focus {
      border-color: #3a5bd9;
      box-shadow: 0 0 0 3px rgba(58,91,217,.12);
    }
    .form-ctrl::placeholder { color: #bbc; }

    .btn-save {
      background: #3a5bd9; color: #fff;
      border: none; border-radius: 8px;
      padding: 11px 28px; font-size: .92rem;
      font-weight: 600; cursor: pointer;
      transition: background .2s;
      float: right;
    }
    .btn-save:hover { background: #2a4bc9; }

    /* ── FOOTER ── */
    footer { background: #111827; color: #ccc; padding: 55px 0 28px; }
    .footer-feedback {
      background: #1e2a3a; border-radius: 10px; padding: 26px 24px;
    }
    .footer-feedback .badge-fb {
      font-size: .65rem; color: #4a90d9; letter-spacing: 2px;
      text-transform: uppercase; font-weight: 700;
      display: block; margin-bottom: 10px;
    }
    .footer-feedback h4 {
      color: #aaa; font-size: 1rem; font-weight: 400;
      line-height: 1.5; margin-bottom: 16px;
    }
    .footer-feedback h4 strong { color: #fff; font-weight: 700; }
    .footer-input-wrap { position: relative; margin-bottom: 10px; }
    .footer-input-icon {
      position: absolute; left: 12px; top: 50%;
      transform: translateY(-50%); color: #557; font-size: .85rem;
    }
    .footer-input {
      width: 100%; background: transparent;
      border: 1px solid #334; border-radius: 6px; color: #ccc;
      padding: 10px 12px 10px 34px; font-size: .85rem;
      outline: none; transition: border-color .2s;
    }
    .footer-input::placeholder { color: #556; }
    .footer-input:focus { border-color: #4a90d9; }
    .btn-send {
      background: #4a90d9; color: #fff; border: none;
      padding: 10px 22px; border-radius: 6px; font-weight: 600;
      font-size: .88rem; cursor: pointer; transition: background .2s; margin-top: 6px;
    }
    .btn-send:hover { background: #3a7bc8; }
    .footer-privacy { font-size: .72rem; color: #445; margin-top: 10px; }
    footer h6 {
      color: #4a90d9; font-weight: 700; font-size: .72rem;
      letter-spacing: 2px; text-transform: uppercase; margin-bottom: 16px;
    }
    footer ul { list-style: none; padding: 0; }
    footer ul li { margin-bottom: 8px; }
    footer a { color: #ccc; text-decoration: none; font-size: .88rem; font-weight: 500; }
    footer a:hover { color: #fff; }
    .footer-contact p { font-size: .88rem; margin-bottom: 4px; color: #ccc; }
    .footer-contact a { color: #4a90d9; }
    .social-icons { display: flex; gap: 12px; margin-top: 20px; }
    .social-icons a {
      width: 38px; height: 38px; border-radius: 50%;
      background: #1e2a3a;
      display: flex; align-items: center; justify-content: center;
      color: #ccc; font-size: .9rem;
      transition: background .2s, color .2s;
    }
    .social-icons a:hover { background: #4a90d9; color: #fff; }
    .footer-bottom {
      border-top: 1px solid #1e2a3a; margin-top: 40px;
      padding-top: 16px; font-size: .75rem; color: #445; text-align: right;
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 767px) {
      .sidebar { margin-bottom: 20px; }
      .panel-body { padding: 20px 16px 24px; }
      .btn-save { float: none; width: 100%; margin-top: 12px; }
      .avatar-col { display: flex; flex-direction: column; align-items: center; }
    }
  </style>
</head>
<body>

<!-- ── NAVBAR ── -->
<nav class="navbar-top">
  <div class="container d-flex align-items-center justify-content-between flex-wrap gap-2">
    <a class="brand-box" href="#">
      <span class="brand-icon">
        <i class="fa-solid fa-circle-nodes" style="font-size:.6rem"></i>
      </span>
      LapHUB
    </a>
    <button class="navbar-toggler d-lg-none border-0 bg-transparent" type="button"
      data-bs-toggle="collapse" data-bs-target="#mainNav">
      <i class="fa-solid fa-bars" style="font-size:1.2rem;color:#333"></i>
    </button>
    <div class="collapse navbar-collapse d-lg-flex align-items-center justify-content-center flex-grow-1" id="mainNav">
      <div class="d-flex flex-column flex-lg-row gap-1 gap-lg-0 mt-3 mt-lg-0">
        <a class="nav-link" href="#">Home</a>
        <a class="nav-link" href="#">Contact</a>
        <a class="nav-link" href="#">About</a>
        <a class="nav-link nav-products" href="#">Products</a>
      </div>
    </div>
    <div class="navbar-icons">
      <a href="#"><i class="fa-regular fa-heart"></i></a>
      <a href="#" style="position:relative">
        <i class="fa-solid fa-cart-shopping"></i>
        <span class="cart-badge">1</span>
      </a>
      <span class="navbar-username">Surya Jith</span>
    </div>
  </div>
</nav>

<!-- ── MAIN ── -->
<div class="main-content">
  <div class="container">
    <div class="row g-4">

      <!-- SIDEBAR -->
      <div class="col-lg-3 col-md-4">
        <div class="sidebar">
          <a class="sidebar-item" href="#"><i class="fa-solid fa-table-cells-large"></i> Dashboard</a>
          <a class="sidebar-item active" href="#"><i class="fa-regular fa-user"></i> Account Details</a>
          <a class="sidebar-item" href="#"><i class="fa-regular fa-clock"></i> Order History</a>
          <a class="sidebar-item" href="#"><i class="fa-solid fa-cart-shopping"></i> Shopping Cart</a>
          <a class="sidebar-item" href="#"><i class="fa-regular fa-heart"></i> Wishlist</a>
          <a class="sidebar-item" href="#"><i class="fa-regular fa-credit-card"></i> Address</a>
          <a class="sidebar-item" href="#"><i class="fa-solid fa-wallet"></i> Wallet</a>
        </div>
      </div>

      <!-- CONTENT -->
      <div class="col-lg-9 col-md-8">
        <div class="panel-card">
          <div class="panel-header">Account Setting</div>
          <div class="panel-body">
            <div class="row g-4 align-items-start">

              <!-- Avatar column -->
              <div class="col-auto avatar-col">
                <div class="avatar-circle">
                  <!--
                    IMAGE SLOT:
                    Replace <i> tag with:
                    <img src="avatar.jpg" alt="Profile"
                         style="width:100%;height:100%;object-fit:cover"/>
                  -->
                  <i class="fa-solid fa-user"></i>
                </div>
                <button class="btn-update-photo" type="button">Update photo</button>
              </div>

              <!-- Fields column -->
              <div class="col">
                <!-- Name -->
                <div class="mb-3">
                  <label class="form-label-sm">Name</label>
                  <input type="text" class="form-ctrl" value="Surya Jith"/>
                </div>

                <!-- Phone Number -->
                <div class="mb-4">
                  <label class="form-label-sm">Phone Number</label>
                  <input type="tel" class="form-ctrl" value="+91 000000000" style="max-width:280px"/>
                </div>

                <!-- Save Changes button — right aligned -->
                <div class="clearfix">
                  <button class="btn-save" type="button">Save Changes</button>
                </div>
              </div>

            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>

<!-- ── FOOTER ── -->
<footer>
  <div class="container">
    <div class="row g-5">

      <!-- Feedback -->
      <div class="col-lg-3 col-md-6">
        <div class="footer-feedback">
          <span class="badge-fb">Feedback</span>
          <h4>Seeking personalized support? <strong>Request a call from our team</strong></h4>
          <div class="footer-input-wrap">
            <i class="fa-regular fa-envelope footer-input-icon"></i>
            <input class="footer-input" type="email" placeholder="example@email.com"/>
          </div>
          <div class="footer-input-wrap">
            <i class="fa-regular fa-user footer-input-icon"></i>
            <input class="footer-input" type="text" placeholder="Enter your  Username."/>
          </div>
          <button class="btn-send">Send Request</button>
          <p class="footer-privacy">Privacy</p>
        </div>
      </div>

      <!-- Info -->
      <div class="col-lg-2 col-md-3 col-6">
        <h6>Info</h6>
        <ul>
          <li><a href="#">Company</a></li>
          <li><a href="#">Products</a></li>
          <li><a href="#">Engineering</a></li>
          <li><a href="#">Services</a></li>
          <li><a href="#">Productions</a></li>
        </ul>
      </div>

      <!-- About Us -->
      <div class="col-lg-2 col-md-3 col-6">
        <h6>About Us</h6>
        <ul>
          <li><a href="#">Gallery</a></li>
          <li><a href="#">Technologies</a></li>
          <li><a href="#">Contacts</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div class="col-lg-3 col-md-6 footer-contact">
        <h6>Contact Us</h6>
        <p>+91 8848837834</p>
        <p><a href="mailto:help@laptopSU.com">help@laptopSU.com</a></p>
        <p>KOCHI, KL, INDIA</p>
        <div class="social-icons">
          <a href="#"><i class="fa-brands fa-facebook-f"></i></a>
          <a href="#"><i class="fa-brands fa-instagram"></i></a>
          <a href="#"><i class="fa-brands fa-youtube"></i></a>
          <a href="#"><i class="fa-brands fa-x-twitter"></i></a>
        </div>
      </div>

    </div>
    <div class="footer-bottom">© 2025 — ESE</div>
  </div>
</footer>

<script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/js/bootstrap.bundle.min.js"></script>
</body>
</html>