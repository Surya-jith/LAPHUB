<%- include('../partials/header', { title: "Home" }) %>


<link rel="stylesheet" href="/css/layout.css">
<link rel="stylesheet" href="/css/user/home.css">

<!-- HERO SECTION -->
<section class="hero-section">

  <div class="hero-overlay">

    <h3>INDIA'S LARGEST</h3>

    <h1>LAPTOP STORE</h1>

    <a href="/products" class="hero-btn">
      Explore Laptops
    </a>

  </div>

</section>


<!-- TAGLINE -->
<section class="tagline">

  <h2>
    Get your Laptop <br>
    as soon as possible !
  </h2>

</section>


<!-- CATEGORY BRANDS -->
<section class="categories">

  <h2>Choose your Choice !</h2>

  <div class="brand-container">

    <div class="brand-card">
      <img src="/images/brands/dell.png" alt="Dell">
    </div>

    <div class="brand-card">
      <img src="/images/brands/hp.png" alt="HP">
    </div>

    <div class="brand-card">
      <img src="/images/brands/asus.png" alt="Asus">
    </div>

    <div class="brand-card">
      <img src="/images/brands/lenovo.png" alt="Lenovo">
    </div>

    <div class="brand-card">
      <img src="/images/brands/acer.png" alt="Acer">
    </div>

    <div class="brand-card">
      <img src="/images/brands/msi.png" alt="MSI">
    </div>

  </div>

</section>


<!-- PROMO BANNER -->
<section class="promo-banner">

  <div class="promo-overlay">

    <h2>BOUNDLESS POWER</h2>

    <p>ROG GAMING 2024</p>

    <button class="promo-btn">
      Available Now
    </button>

  </div>

</section>


<!-- FEATURED PRODUCTS PLACEHOLDER -->
<section class="products">

  <h2>Featured Laptops</h2>

  <div class="product-grid">

    <div class="product-card">

      <div class="product-image"></div>

      <h4>Dell Inspiron</h4>

      <p>₹53,990</p>

    </div>


    <div class="product-card">

      <div class="product-image"></div>

      <h4>HP Pavilion</h4>

      <p>₹61,999</p>

    </div>


    <div class="product-card">

      <div class="product-image"></div>

      <h4>ASUS ROG</h4>

      <p>₹95,000</p>

    </div>


    <div class="product-card">

      <div class="product-image"></div>

      <h4>Lenovo Legion</h4>

      <p>₹88,999</p>

    </div>

  </div>

</section>


<!-- CALL TO ACTION -->
<section class="cta-section">

  <h2>Upgrade Your Power Today</h2>

  <p>Find the perfect laptop for work, gaming, and creativity.</p>

  <a href="/products" class="cta-btn">
    Shop Now
  </a>

</section>


<%- include('../partials/footer') %>