
<%- include('../partials/header', { title: "Home" }) %>

<link rel="stylesheet" href="/css/layout.css">
<link rel="stylesheet" href="/css/user/home.css">

<!-- HERO SECTION -->
<section class="hero-section">

  <div class="hero-overlay">

    <div class="hero-content">
      <h3 class="hero-subtitle">INDIA'S LARGEST</h3>

      <h1 class="hero-title">LAPTOP STORE</h1>

      <p class="hero-description">
        Discover high-performance laptops for gaming, work, and creativity.
      </p>

      <a href="/products" class="hero-btn">
        Explore Laptops
      </a>
    </div>

  </div>

</section>


<!-- TAGLINE -->
<section class="tagline">

  <div class="tagline-container">

    <h2>
      Get your Laptop <br>
      as soon as possible !
    </h2>

    <p>
      Premium laptops from the world's leading brands delivered to your door.
    </p>

  </div>

</section>


<!-- CATEGORY BRANDS -->
<section class="categories">

  <div class="section-header">
    <h2>Choose your Brand</h2>
    <p>Select from the most trusted laptop manufacturers</p>
  </div>

  <div class="brand-container">

    <div class="brand-card">
      <img src="/images/brands/dell.png" alt="Dell">
    </div>

    <div class="brand-card">
      <img src="/images/brands/hp.png" alt="HP">
    </div>

    <div class="brand-card">
      <img src="/images/brands/asus.png" alt="Asus">
    </div>

    <div class="brand-card">
      <img src="/images/brands/lenovo.png" alt="Lenovo">
    </div>

    <div class="brand-card">
      <img src="/images/brands/acer.png" alt="Acer">
    </div>

    <div class="brand-card">
      <img src="/images/brands/msi.png" alt="MSI">
    </div>

  </div>

</section>


<!-- PROMO BANNER -->
<section class="promo-banner">

  <div class="promo-overlay">

    <div class="promo-content">
      <h2>BOUNDLESS POWER</h2>

      <p>ROG GAMING 2024</p>

      <button class="promo-btn">
        Available Now
      </button>
    </div>

  </div>

</section>


<!-- FEATURED PRODUCTS -->
<section class="products">

  <div class="section-header">
    <h2>Featured Laptops</h2>
    <p>Top selling laptops loved by professionals and gamers</p>
  </div>

  <div class="product-grid">

    <div class="product-card">

      <div class="product-image"></div>

      <div class="product-info">
        <h4>Dell Inspiron</h4>
        <p class="price">₹53,990</p>
      </div>

    </div>


    <div class="product-card">

      <div class="product-image"></div>

      <div class="product-info">
        <h4>HP Pavilion</h4>
        <p class="price">₹61,999</p>
      </div>

    </div>


    <div class="product-card">

      <div class="product-image"></div>

      <div class="product-info">
        <h4>ASUS ROG</h4>
        <p class="price">₹95,000</p>
      </div>

    </div>


    <div class="product-card">

      <div class="product-image"></div>

      <div class="product-info">
        <h4>Lenovo Legion</h4>
        <p class="price">₹88,999</p>
      </div>

    </div>

  </div>

</section>


<!-- CALL TO ACTION -->
<section class="cta-section">

  <div class="cta-container">

    <h2>Upgrade Your Power Today</h2>

    <p>
      Find the perfect laptop for work, gaming, and creativity.
    </p>

    <a href="/products" class="cta-btn">
      Shop Now
    </a>

  </div>

</section>

<%- include('../partials/footer') %>

