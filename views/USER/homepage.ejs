<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>LapHUB – India's Largest Laptop Store</title>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/css/bootstrap.min.css" rel="stylesheet"/>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700;900&family=Barlow:wght@400;500;600&display=swap" rel="stylesheet"/>
  <style>
    :root {
      --purple: #5b2d8e;
      --gold: #f5c518;
      --dark: #111;
      --accent: #ff6b00;
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Barlow', sans-serif; overflow-x: hidden; }

    /* ── TOP NAVBAR ── */
    .navbar-top {
      background: #fff;
      box-shadow: 0 2px 8px rgba(0,0,0,.08);
      padding: 10px 0;
    }
    .navbar-top .nav-link { color: #333; font-weight: 500; font-size: .95rem; }
    .navbar-top .nav-link:hover { color: var(--purple); }
    .brand-box {
      background: #000;
      color: #fff;
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: 1.1rem;
      padding: 6px 12px;
      letter-spacing: 1px;
    }

    /* ── HERO BANNER ── */
    .hero {
      background: linear-gradient(135deg, #3a1a6e 0%, #6b34a8 50%, #9b59b6 100%);
      min-height: 280px;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 60px 20px;
      position: relative;
      overflow: hidden;
    }
    .hero::before {
      content: '';
      position: absolute; inset: 0;
      background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" width="100" height="100"><circle cx="50" cy="50" r="40" fill="none" stroke="rgba(255,255,255,.05)" stroke-width="2"/></svg>') repeat;
      opacity: .4;
    }
    .hero-sub {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: clamp(1.2rem, 4vw, 2rem);
      color: #fff;
      letter-spacing: 8px;
      text-transform: uppercase;
    }
    .hero-title {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: clamp(3rem, 12vw, 6.5rem);
      color: var(--gold);
      line-height: 1;
      text-transform: uppercase;
      letter-spacing: 2px;
    }

    /* ── DELIVERY STRIP ── */
    .delivery-strip {
      background: #f5f5f5;
      padding: 40px 20px;
      text-align: center;
    }
    .delivery-strip h2 {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: clamp(2rem, 5vw, 3rem);
      color: #111;
    }

    /* ── SECOND NAVBAR ── */
    .navbar-secondary {
      background: #fff;
      border-top: 1px solid #eee;
      border-bottom: 1px solid #eee;
      padding: 12px 0;
    }
    .navbar-secondary .nav-link { color: #333; font-size: .9rem; font-weight: 500; }
    .navbar-secondary .nav-link:hover { color: var(--purple); }

    /* ── BRANDS SECTION ── */
    .brands-section {
      padding: 60px 20px;
      background: #fff;
      text-align: center;
    }
    .brands-section h2 {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: 2rem;
      margin-bottom: 40px;
      color: #111;
    }
    .brand-circle {
      width: 120px; height: 120px;
      border-radius: 50%;
      background: #fff;
      display: flex; align-items: center; justify-content: center;
      margin: 0 auto 12px;
      border: 3px solid transparent;
      box-shadow: 0 4px 16px rgba(0,0,0,.1);
      position: relative;
      transition: transform .3s, box-shadow .3s;
      background-clip: padding-box;
    }
    .brand-circle::before {
      content: '';
      position: absolute; inset: -3px;
      border-radius: 50%;
      background: conic-gradient(#ff9933 0deg 120deg, #fff 120deg 240deg, #138808 240deg 360deg);
      z-index: -1;
    }
    .brand-circle img { max-width: 70px; max-height: 45px; object-fit: contain; }
    .brand-circle:hover { transform: scale(1.08); box-shadow: 0 8px 24px rgba(0,0,0,.15); }
    .brand-name { font-weight: 700; font-size: .85rem; color: #555; }

    /* Brand logo placeholders using styled text */
    .logo-asus { font-family: 'Barlow Condensed', sans-serif; font-weight: 900; font-size: 1.4rem; color: #1a1a1a; }
    .logo-dell { font-family: 'Barlow Condensed', sans-serif; font-weight: 900; font-size: 1.2rem; color: #007db8; }
    .logo-apple { font-size: 2rem; color: #111; }
    .logo-samsung { font-family: 'Barlow Condensed', sans-serif; font-weight: 900; font-size: 1rem; color: #1428a0; letter-spacing: 1px; }
    .logo-msi { font-family: 'Barlow Condensed', sans-serif; font-weight: 900; font-size: 1.6rem; color: #c00; }
    .logo-acer { font-family: 'Barlow Condensed', sans-serif; font-weight: 900; font-size: 1.5rem; color: #83b81a; }

    /* ── GAMING BANNER ── */
    .gaming-banner {
      background: linear-gradient(to bottom, #0a0a0a 0%, #1a0a2e 60%, #0d0d0d 100%);
      padding: 60px 20px;
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .gaming-banner::before {
      content: '';
      position: absolute; inset: 0;
      background: radial-gradient(ellipse at 50% 40%, rgba(100,50,200,.3) 0%, transparent 70%);
    }
    .gaming-laptops {
      display: flex;
      align-items: flex-end;
      justify-content: center;
      gap: 20px;
      margin-bottom: 30px;
      position: relative;
    }
    .laptop-card-gaming {
      background: linear-gradient(145deg, #1e1e2e, #2d1b69);
      border: 1px solid rgba(150,100,255,.3);
      border-radius: 12px;
      padding: 20px;
      position: relative;
      box-shadow: 0 0 40px rgba(100,50,255,.2);
    }
    .laptop-card-gaming .laptop-name {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: .85rem;
      color: rgba(255,255,255,.7);
      letter-spacing: 2px;
      text-transform: uppercase;
      margin-bottom: 12px;
    }
    .laptop-card-gaming .laptop-icon {
      font-size: 4rem;
      color: #a78bfa;
    }
    .laptop-center { transform: scale(1.15); z-index: 2; }
    .rog-badge {
      position: absolute; top: 10px; right: 10px;
      font-family: 'Barlow Condensed', sans-serif;
      font-size: .7rem;
      color: #ff0000;
      letter-spacing: 1px;
      border: 1px solid #ff0000;
      padding: 2px 6px;
    }
    .gaming-tagline {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: clamp(2rem, 6vw, 4rem);
      color: #c084fc;
      text-transform: uppercase;
      letter-spacing: 4px;
      text-shadow: 0 0 40px rgba(192,132,252,.5);
    }
    .gaming-subtitle {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 700;
      font-size: 1.4rem;
      color: #fff;
      letter-spacing: 6px;
      text-transform: uppercase;
    }
    .gaming-desc { color: rgba(255,255,255,.65); font-size: .9rem; margin: 8px 0 20px; }
    .btn-gaming {
      border: 1px solid #fff;
      color: #fff;
      background: transparent;
      padding: 8px 30px;
      font-weight: 600;
      letter-spacing: 1px;
      transition: all .3s;
    }
    .btn-gaming:hover { background: #fff; color: #000; }

    /* ── PRODUCT CARDS ── */
    .products-section {
      padding: 40px 20px;
      background: #f8f8f8;
    }
    .product-card {
      background: #fff;
      border: 1px solid #eee;
      border-radius: 8px;
      overflow: hidden;
      transition: box-shadow .3s, transform .3s;
      height: 100%;
    }
    .product-card:hover { box-shadow: 0 8px 32px rgba(0,0,0,.12); transform: translateY(-4px); }
    .product-card .badge-gen {
      position: absolute; top: 12px; left: 12px;
      background: var(--accent);
      color: #fff;
      font-size: .7rem;
      font-weight: 700;
      padding: 3px 8px;
      border-radius: 3px;
    }
    .product-card .badge-best {
      position: absolute; top: 12px; right: 12px;
      background: var(--purple);
      color: #fff;
      font-size: .7rem;
      font-weight: 700;
      padding: 3px 8px;
      border-radius: 3px;
    }
    .product-img-wrap {
      position: relative;
      background: #f0f0f0;
      display: flex; align-items: center; justify-content: center;
      height: 180px;
    }
    .product-img-wrap i { font-size: 5rem; color: #bbb; }
    /* brand-colored icons */
    .icon-dell { color: #007db8; }
    .icon-asus { color: #1a1a1a; }
    .icon-hp { color: #0096d6; }
    .icon-acer { color: #83b81a; }
    .product-body { padding: 16px; }
    .product-body .brand { font-weight: 700; font-size: .9rem; color: #333; }
    .product-body .specs { font-size: .78rem; color: #777; line-height: 1.5; margin: 6px 0; }
    .product-price {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: 1.5rem;
      color: #111;
    }
    .rupee { font-size: 1rem; }

    /* ── FOOTER ── */
    footer {
      background: #1a1a1a;
      color: #ccc;
      padding: 60px 0 30px;
    }
    .footer-feedback {
      background: #2a2a2a;
      border-radius: 8px;
      padding: 28px;
    }
    .footer-feedback .badge-fb {
      font-size: .65rem;
      color: var(--gold);
      letter-spacing: 2px;
      text-transform: uppercase;
      display: block;
      margin-bottom: 8px;
    }
    .footer-feedback h4 { color: #fff; font-size: 1.1rem; line-height: 1.4; }
    .footer-feedback h4 strong { color: #fff; font-weight: 700; }
    .footer-input {
      background: #3a3a3a;
      border: none;
      color: #fff;
      padding: 10px 14px;
      border-radius: 4px;
      font-size: .85rem;
      width: 100%;
    }
    .footer-input::placeholder { color: #888; }
    .footer-input:focus { outline: 1px solid var(--purple); }
    .btn-send {
      background: #4a90d9;
      color: #fff;
      border: none;
      padding: 10px 24px;
      border-radius: 4px;
      font-weight: 600;
      font-size: .9rem;
      transition: background .2s;
    }
    .btn-send:hover { background: #3a7bc8; }
    footer h6 {
      color: #fff;
      font-weight: 700;
      font-size: .75rem;
      letter-spacing: 2px;
      text-transform: uppercase;
      margin-bottom: 16px;
    }
    footer a { color: #bbb; text-decoration: none; font-size: .88rem; }
    footer a:hover { color: #fff; }
    footer ul { list-style: none; padding: 0; }
    footer ul li { margin-bottom: 8px; }
    .footer-contact p { font-size: .88rem; margin-bottom: 4px; }
    .footer-contact a { color: #4a90d9; }
    .social-icons a {
      display: inline-flex; align-items: center; justify-content: center;
      width: 36px; height: 36px;
      border: 1px solid #444;
      border-radius: 50%;
      color: #bbb;
      font-size: .85rem;
      margin-right: 8px;
      transition: all .2s;
    }
    .social-icons a:hover { border-color: #fff; color: #fff; }
    .footer-brand-box {
      background: #000;
      color: #fff;
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: 1.1rem;
      padding: 6px 12px;
      display: inline-block;
    }
    .footer-bottom {
      border-top: 1px solid #333;
      margin-top: 40px;
      padding-top: 16px;
      font-size: .78rem;
      color: #666;
    }
  </style>
</head>
