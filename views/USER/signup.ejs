<!DOCTYPE html>
<html>
<head>
  <title>Signup</title>
  <link rel="stylesheet" href="/css/user/signup.css">
</head>
<body>

<div class="main-container">

  <!-- LEFT IMAGE PLACEHOLDER -->
  <div class="left-section">
    <div class="logo-placeholder">
      <img src="/images/logo.png" alt="LapHUB Logo" class="logo-img">
    </div>
  </div>

  <!-- RIGHT SIGNUP CARD -->
  <div class="right-section">
    <div class="signup-card">

      <h2>Signup</h2>
      <% if (error) { %>
  <div class="error-message">
    <%= error %>
  </div>
<% } %>

      <form action="/signup" method="POST">

        <div class="input-group">
          <label>Username</label>
          <input type="text"
       name="username"
       placeholder="ex: Surya jith"
       value="<%= oldData ? oldData.username : '' %>"
       required>
        </div>

        <div class="input-group">
          <label>Email</label>
         <input type="email"
       name="email"
       placeholder="example@email.com"
       value="<%= oldData ? oldData.email : '' %>"
       required>
        </div>

        <div class="input-group">
          <label>Password</label>
          <input type="password" name="password" placeholder="Enter your password" required>
        </div>

        <div class="input-group">
          <label>Confirm Password</label>
          <input type="password" name="confirmPassword" placeholder="Enter your password" required>
        </div>

        <div class="input-group">
          <label>Phone Number (Optional)</label>
          <input type="text"
       name="phone"
       placeholder="Enter your phone number"
       value="<%= oldData ? oldData.phone : '' %>">
        </div>

        <button type="submit" class="signup-btn">Signup</button>

        <div class="input-group referral-section">
          <label>Referral code (Optional)</label>
          <input type="text" name="referralCode" placeholder="Enter code">
        </div>

        <div class="login-link">
          Already have an account?
          <a href="/login">Login Now</a>
        </div>

        <div class="divider">OR</div>

        <a href="/auth/google">
  Continue with Google
</a>

      </form>

    </div>
  </div>

</div>

</body>
</html>