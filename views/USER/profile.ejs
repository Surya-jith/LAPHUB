<!DOCTYPE html>
<html>

<head>
<title>Account Settings</title>
<link
  rel="stylesheet"
  href="/css/common.css"
>
<link rel="stylesheet" href="/css/layout.css">
<link rel="stylesheet" href="/css/user/profile.css">
<% if (typeof error !== "undefined" && error) { %>
  <div class="error-message">
    <%= error %>
  </div>
<% } %>
</head>

<body>

<%- include('../partials/header',{ user }) %>

<div class="page-layout">

  <%- include('../partials/userSidebar', {
    activePage: 'profile'
  }) %>

  <div class="main-content">

    <div class="profile-card">

      <div class="card-header">

        <h3>ACCOUNT SETTING</h3>

        <a href="/profile/edit" class="edit-profile-btn">
          EDIT PROFILE
        </a>

      </div>

      <div class="profile-body">

        <!-- PROFILE IMAGE -->

        <div class="profile-image">

          <img
            src="<%= user.profileImage ? '/uploads/profile/' + user.profileImage : '/images/user.png' %>"
            alt="User Image"
          >

        </div>

        <!-- PROFILE DETAILS -->

        <div class="profile-details">

          <div class="row">

            <div class="field">

              <label>Name</label>

              <input
                type="text"
                value="<%= user.username %>"
                readonly
              >

            </div>

            <div class="field">

              <label>Email</label>

              <input
                type="text"
                value="<%= user.email %>"
                readonly
              >

              <a
                href="/edit-email"
                class="edit-email-btn"
              >
                EDIT EMAIL
              </a>

            </div>

          </div>

          <div class="row">

            <div class="field">

              <label>Phone Number</label>

              <input
                type="text"
                value="<%= user.phone %>"
                readonly
              >

            </div>

          </div>

          <div class="referral-section">

            <p>Your referral code</p>

            <span class="referral-code">
              <%= user.referralCode %>
            </span>

          </div>

          <a
            href="/change-password"
            class="change-password-btn"
          >
            Change Password
          </a>

        </div>

      </div>

    </div>

  </div>

</div>

<%- include('../partials/footer') %>

</body>
</html>