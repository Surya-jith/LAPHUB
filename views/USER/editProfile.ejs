<!DOCTYPE html>
<html>

<head>
  <title>Edit Profile</title>
  <link rel="stylesheet" href="/css/common.css">
  <link rel="stylesheet" href="/css/layout.css">
  <link rel="stylesheet" href="/css/user/profile.css">
</head>

<body>

<%- include('../partials/header',{ user }) %>

<div class="profile-page">

  <!-- SIDEBAR -->
  <div class="profile-sidebar">
    <ul>
      <li><a href="/profile">Dashboard</a></li>
      <li class="active"><a href="/profile/edit">Account Details</a></li>
      <li><a href="/orders">Order History</a></li>
      <li><a href="/cart">Shopping Cart</a></li>
      <li><a href="/wishlist">Wishlist</a></li>
      <li><a href="/address">Address</a></li>
      <li><a href="/wallet">Wallet</a></li>
    </ul>
  </div>

  <!-- PROFILE CARD -->
  <div class="profile-card">

    <div class="card-header">
      <h3>EDIT PROFILE</h3>
    </div>

    <!-- ERROR MESSAGE -->
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="error-message">
        <%= error %>
      </div>
    <% } %>

    <!-- SUCCESS MESSAGE -->
    <% if (typeof success !== 'undefined' && success) { %>
      <div class="success-message">
        <%= success %>
      </div>
    <% } %>

    <form class="profile-body" action="/profile/edit" method="POST" enctype="multipart/form-data">

      <!-- PROFILE IMAGE -->
      <div class="profile-image">

        <% if (user.profileImage && user.profileImage.trim() && user.profileImage !== "null") { %>
          <img
            src="/uploads/profile/<%= user.profileImage %>"
            alt="User Image"
            onerror="this.style.display='none'; document.getElementById('default-avatar').style.display='flex';"
          >
          <div id="default-avatar" class="default-avatar" style="display:none;">
            <i class="fa-solid fa-user"></i>
          </div>
        <% } else { %>
          <img src="/images/default-profile.png" alt="Default User Image" onerror="this.style.display='none'; document.getElementById('default-avatar').style.display='flex';">
          <div id="default-avatar" class="default-avatar" style="display:none;">
            <i class="fa-solid fa-user"></i>
          </div>
        <% } %>

        <input type="file" name="profileImage" class="photo-btn" accept="image/*">
        <small class="photo-hint">JPG, PNG, or WebP</small>

      </div>

      <!-- PROFILE FORM -->
      <div class="profile-details">

        <div class="row">
          <div class="field">
            <label>Name</label>
            <input
              type="text"
              name="username"
              value="<%= user.username %>"
              required
              minlength="2"
              maxlength="30"
            >
          </div>
        </div>

        <div class="row">
          <div class="field">
            <label>Phone Number</label>
            <input
              type="text"
              name="phone"
              value="<%= user.phone || '' %>"
              placeholder="Enter 10-digit phone number"
              maxlength="10"
              pattern="[0-9]{10}"
            >
          </div>
        </div>

        <div class="save-section">
          <button type="submit" class="save-btn">Save Changes</button>
          <a href="/profile" class="btn-cancel" style="margin-left:10px;">Cancel</a>
        </div>

      </div>

    </form>

  </div>

</div>

<%- include('../partials/footer') %>

</body>
</html>
