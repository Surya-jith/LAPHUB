<%- include('../partials/header', { user: user }) %>

<link rel="stylesheet" href="/css/layout.css">
<link rel="stylesheet" href="/css/user/cart.css">

<section class="cart-page">

<div class="cart-container">

<!-- LEFT SIDE -->
<div class="cart-left">

<h2>Shopping Cart</h2>

<div class="cart-header">
<span>Products</span>
<span>Price</span>
<span>Quantity</span>
<span>Sub-Total</span>
</div>

<% if(cartItems.length > 0){ %>

<% cartItems.forEach(item => { %>

<div class="cart-item 
<%= !item.variant || item.variant.stock === 0 || item.product.isBlocked || !item.product.isListed ? 'disabled-product' : '' %>">

<!-- Remove -->
<div class="remove-item">
<a href="/remove-cart/<%= item.product._id %>">
<i class="fa fa-times"></i>
</a>
</div>

<!-- Product -->
<div class="cart-product">

<img src="<%= item.product.images?.[0] || '' %>" alt="">

<div class="product-name">
<%= item.product.name %>

<% if(!item.variant || item.variant.stock === 0){ %>
<span class="out-stock">Out of Stock</span>
<% } %>

</div>

</div>


<!-- Price -->
<div class="cart-price">

<% if(item.variant){ %>

₹<%= item.variant.price %>

<% } else { %>

<span class="out-stock">
Unavailable
</span>

<% } %>

</div>



<!-- Quantity -->
<div class="cart-qty">

<button 
class="qty-btn minus"
data-id="<%= item.product._id %>"
<%= !item.variant || item.variant.stock === 0 ? 'disabled' : '' %>
>-</button>

<input 
type="text" 
value="<%= item.quantity %>" 
readonly
>

<button 
class="qty-btn plus"
data-id="<%= item.product._id %>"
<%= !item.variant || item.variant.stock === 0 || item.quantity >= item.variant.stock ? 'disabled' : '' %>
>+</button>

</div>


<!-- Subtotal -->
<div class="cart-subtotal">

₹<%= item.subtotal %>

</div>

</div>

<% }) %>

<% } else { %>

<div class="empty-cart">
Cart is empty
</div>

<% } %>


</div>



<!-- RIGHT SIDE -->
<div class="cart-right">

<!-- Totals -->
<div class="cart-card">

<h3>Cart Totals</h3>

<div class="cart-row">
<span>Sub-total</span>
<span>₹<%= subtotal %></span>
</div>

<div class="cart-row">
<span>Shipping</span>
<span>Free</span>
</div>

<div class="cart-row">
<span>Discount</span>
<span>₹<%= discount %></span>
</div>

<div class="cart-row">
<span>Tax</span>
<span>₹<%= tax %></span>
</div>

<hr>

<div class="cart-total">
<span>Total</span>
<span>₹<%= total %></span>
</div>

<button 
class="checkout-btn"
<%= disableCheckout ? 'disabled' : '' %>
>
Proceed To Checkout
</button>

</div>


<!-- Coupon -->
<div class="cart-card">

<h3>Coupon Code</h3>

<form action="/apply-coupon" method="POST">

<input 
type="text" 
name="coupon"
placeholder="Coupon code"
>

<button type="submit">
Apply Coupon
</button>

</form>

</div>

</div>

</div>

</section>



<script>

document.querySelectorAll(".plus").forEach(btn=>{
btn.addEventListener("click",()=>{

if(btn.disabled) return

const id = btn.dataset.id
window.location.href = `/cart/increase/${id}`

})
})


document.querySelectorAll(".minus").forEach(btn=>{
btn.addEventListener("click",()=>{

if(btn.disabled) return

const id = btn.dataset.id
window.location.href = `/cart/decrease/${id}`

})
})

</script>


<%- include('../partials/footer') %>