<%- include('../partials/header', { user: user }) %>
<link rel="stylesheet" href="/css/user/checkout.css">
<% if(typeof error !== "undefined" && error){ %>
  <div class="error-box">
    <%= error %>
  </div>
<% } %>
<section class="checkout">

<div class="checkout-wrapper">

<form action="/place-order" method="POST">

  <!-- LEFT -->
  <div class="checkout-left">

    <div class="card">

      <div class="card-header">
        <h3>Billing Details</h3>

      
        <a href="/add-address?redirect=/checkout">
  + Add Address
</a>
      </div>

      <% if(addresses.length > 0){ %>

      <div class="address-list">

        <% addresses.forEach(addr => { %>

        <label class="address-item">

          <!-- RADIO -->
          <input 
            type="radio" 
            name="address" 
            value="<%= addr._id %>"
            <%= addr._id.toString() === defaultAddress?._id?.toString() ? 'checked' : '' %>
          >

          <div class="address-content">

            <!-- TOP -->
            <div class="address-top">
              <h4><%= addr.firstName %> <%= addr.lastName %></h4>

              <a href="/edit-address/<%= addr._id %>?redirect=/checkout">
  Edit
</a>
            </div>

            <!-- ADDRESS -->
            <p><%= addr.address %>, <%= addr.city %></p>
            <p><%= addr.state %> - <%= addr.pincode %></p>

            <!-- BOTTOM -->
            <div class="address-bottom">
              <span><%= addr.phone %></span>

              <% if(addr.isDefault){ %>
                <span class="default-badge">Default</span>
              <% } %>
            </div>

          </div>

        </label>

        <% }) %>

      </div>

      <% } else { %>

        <!-- EMPTY STATE -->
        <div class="empty-address">
          <p>No address found.</p>
          <a href="/add-address" class="add-address-btn">
            + Add your first address
          </a>

        </div>

      <% } %>

    </div>

  </div>


  <!-- RIGHT -->
  <div class="checkout-right">

    <div class="card order-card">

      <h3>Your Order</h3>

      <div class="order-items">

        <% cartItems.forEach(item => { %>

        <div class="order-item">

          <img src="<%= item.image %>" alt="product">

          <div class="info">
            <p><%= item.name %></p>
            <span>Qty: <%= item.quantity %></span>
          </div>

          <div class="price">
            ₹<%= item.itemTotal %>
          </div>

        </div>

        <% }) %>

      </div>

      <!-- SUMMARY -->
      <div class="summary">

        <div class="row">
          <span>Subtotal</span>
          <span>₹<%= subtotal %></span>
        </div>

        <div class="row">
          <span>Tax</span>
          <span>₹<%= tax %></span>
        </div>

        <div class="row total">
          <span>Total</span>
          <span>₹<%= total %></span>
        </div>

      </div>

      <!-- PAYMENT -->
      <div class="payment">
        <label>
          <input type="radio" name="paymentMethod" value="COD" checked>
          Cash on Delivery
        </label>
      </div>

      <!-- BUTTON -->
      <button class="place-btn" <%= disableCheckout ? 'disabled' : '' %>>
        Place Order
      </button>

    </div>

  </div>

</form>

</div>

</section>

<script>
document.querySelectorAll('.address-item').forEach(item => {
  item.addEventListener('click', () => {
    document.querySelectorAll('.address-item').forEach(i => i.classList.remove('selected'));
    item.classList.add('selected');
    item.querySelector('input').checked = true;
  });
});
</script>

<%- include('../partials/footer') %>