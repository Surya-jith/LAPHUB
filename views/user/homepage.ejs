
<%- include('../partials/header', { title: "Home" }) %>
<link
  rel="stylesheet"
  href="/css/common.css"
>
<link rel="stylesheet" href="/css/layout.css">
<link rel="stylesheet" href="/css/user/home.css">
<% if (error) { %>
  <div class="error-message">
    <%= error %>
  </div>
<% } %>
<!-- HERO SECTION -->
<section class="hero-section">

  <div class="hero-overlay">

    <div class="hero-content">
      <h3 class="hero-subtitle">INDIA'S LARGEST</h3>

      <h1 class="hero-title">LAPTOP STORE</h1>

      <p class="hero-description">
        Discover high-performance laptops for gaming, work, and creativity.
      </p>

      <a href="/products" class="hero-btn">
        Explore Laptops
      </a>
    </div>

  </div>

</section>


<!-- TAGLINE -->
<section class="tagline">

  <div class="tagline-container">

    <h2>
      Get your Laptop <br>
      as soon as possible !
    </h2>

    <p>
      Premium laptops from the world's leading brands delivered to your door.
    </p>

  </div>

</section>


<!-- CATEGORY BRANDS -->
<section class="categories">

  <div class="section-header">
    <h2>Shop By Category</h2>

<p>Browse laptops by category</p>
  </div>

 <div class="brand-container">

  <% topCategories.forEach(item => { %>

    <a
      href="/products?category=<%= item.category._id %>"
      class="brand-card"
    >

      <h3>
  <%= item.category.name %>
</h3>

<span>
  <%= item.totalSold %> sales
</span>

    </a>

  <% }) %>

</div>

</section>


<!-- PROMO BANNER -->
<section class="promo-banner">

  <div class="promo-overlay">

    <div class="promo-content">
      <h2>BOUNDLESS POWER</h2>

      <p>ROG GAMING 2024</p>

      <button class="promo-btn">
        Available Now
      </button>
    </div>

  </div>

</section>


<!-- FEATURED PRODUCTS -->
<section class="products">

  <div class="section-header">
   <h2>Top Selling Laptops</h2>

<p>
  Most purchased laptops by our customers
</p>
  </div>

  <div class="product-grid">

  <% topProducts.forEach(item => { %>

    <a
      href="/product/<%= item.product._id %>"
      class="product-card"
    >

      <div class="product-image">

        <img
          src="<%= item.product.images?.[0] || '/images/no-image.png' %>"
          alt="<%= item.product.name %>"
        >

      </div>

      <div class="product-info">

        <h4>
          <%= item.product.name %>
        </h4>

        <p class="price">

          ₹<%= item.product.variants?.[0]?.price || 0 %>

        </p>

        <small>
          Sold:
          <%= item.totalSold %>
        </small>

      </div>

    </a>

  <% }) %>

</div>

</section>


<!-- CALL TO ACTION -->
<section class="cta-section">

  <div class="cta-container">

    <h2>Upgrade Your Power Today</h2>

    <p>
      Find the perfect laptop for work, gaming, and creativity.
    </p>

    <a href="/products" class="cta-btn">
      Shop Now
    </a>

  </div>

</section>

<%- include('../partials/footer') %>

