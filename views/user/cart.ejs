<%- include('../partials/header', { user: user }) %>
<link
  rel="stylesheet"
  href="/css/common.css"
>
<link rel="stylesheet" href="/css/layout.css">
<link rel="stylesheet" href="/css/user/cart.css">
<% if (typeof error !== "undefined" && error) { %>
  <div class="error-message">
    <%= error %>
  </div>
<% } %>
<section class="cart-page">

  <div class="page-layout">

    <%- include('../partials/userSidebar', {
      activePage: 'cart'
    }) %>

    <div class="main-content">

      <div class="cart-container">

        <!-- LEFT SIDE -->
        <div class="cart-left">

          <h2>Shopping Cart</h2>

          <% if (cartItems.length > 0) { %>

            <div class="cart-table-wrapper">

              <table class="cart-table">

                <thead>
                  <tr>
                    <th></th>
                    <th>Products</th>
                    <th>Price</th>
                    <th>Quantity</th>
                    <th>Sub-Total</th>
                  </tr>
                </thead>

                <tbody>

                  <% cartItems.forEach(item => { %>

                    <tr class="<%= (!item.product || !item.variant || item.variant.stock === 0 || item.product?.isBlocked || !item.product?.isListed) ? 'disabled-product' : '' %>">

                      <!-- REMOVE -->
                      <td class="remove-item">
                        <a href="/remove-cart/<%= item.productId %>/<%= item.variantId %>">
                          <i class="fa fa-times"></i>
                        </a>
                      </td>

                      <!-- PRODUCT -->
                      <td class="product-cell">

                        <div class="cart-product">

                          <img
                            src="<%= item.product ? item.product.images?.[0] : '/images/no-image.png' %>"
                            alt="product"
                          >

                          <div class="product-name">

                            <%= item.product ? item.product.name : "Unavailable Product" %>

                            <% if (!item.variant || item.variant?.stock === 0) { %>
                              <span class="out-stock">
                                Out of Stock
                              </span>
                            <% } %>

                            <% if (!item.product) { %>
                              <span class="out-stock">
                                Product Removed
                              </span>
                            <% } %>

                          </div>

                        </div>

                      </td>

                      <!-- PRICE -->
                      <td class="cart-price">

                        <% if (item.variant) { %>
                          ₹<%= item.variant.price %>
                        <% } else { %>
                          <span class="out-stock">
                            Unavailable
                          </span>
                        <% } %>

                      </td>

                      <!-- QUANTITY -->
                      <td>

                        <div class="cart-qty">

                          <button
                            class="qty-btn minus"
                            data-id="<%= item.productId %>"
                            data-variant-id="<%= item.variantId %>"
                            <%= (!item.product || !item.variant || item.variant.stock === 0) ? 'disabled' : '' %>
                          >
                            -
                          </button>

                          <input
                            type="text"
                            value="<%= item.quantity %>"
                            readonly
                          >

                          <button
  class="qty-btn plus"
  data-id="<%= item.productId %>"
  data-variant-id="<%= item.variantId %>"
  <%= (
    !item.product ||
    !item.variant ||
    item.variant.stock === 0 ||
    item.quantity >= item.variant.stock ||
    item.quantity >= 5
  ) ? 'disabled' : '' %>
>
  +
</button>

                        </div>

                        <% if (item.stockWarning) { %>
                          <small class="stock-warning">
                            <%= item.stockWarning %>
                          </small>
                        <% } %>

                      </td>

                      <!-- SUBTOTAL -->
                      <td class="cart-subtotal">
                        ₹<%= item.subtotal %>
                      </td>

                    </tr>

                  <% }) %>

                </tbody>

              </table>

            </div>

          <% } else { %>

            <div class="empty-cart">
              Cart is empty
            </div>

          <% } %>

        </div>

        <!-- RIGHT SIDE -->
        <div class="cart-right">

          <!-- TOTALS -->
          <div class="cart-card">

            <h3>Cart Totals</h3>

            <div class="cart-row">
              <span>Sub-total</span>
              <span>₹<%= subtotal %></span>
            </div>

            <div class="cart-row">
              <span>Shipping</span>
              <span>Free</span>
            </div>

            <div class="cart-row">
              <span>Discount</span>
              <span>₹<%= discount %></span>
            </div>

            <div class="cart-row">
              <span>Tax</span>
              <span>₹<%= tax %></span>
            </div>

            <hr>

            <div class="cart-total">
              <span>Total</span>
              <span>₹<%= total %></span>
            </div>

            <a
              href="/checkout"
              class="checkout-btn <%= disableCheckout ? 'disabled' : '' %>"
            >
              Proceed To Checkout
            </a>

          </div>

          <!-- COUPON
          <div class="cart-card">

            <h3>Coupon Code</h3>

            <form
              action="/apply-coupon"
              method="POST"
            >

              <input
                type="text"
                name="coupon"
                placeholder="Coupon code"
              >

              <button type="submit">
                Apply Coupon
              </button>

            </form>

          </div> -->

        </div>

      </div>

    </div>

  </div>

</section>

<script>
document.querySelectorAll(".plus").forEach(btn => {
  btn.addEventListener("click", () => {
    if (btn.disabled) return;
    const id = btn.dataset.id;
    const variantId = btn.dataset.variantId;
    if (!id || !variantId) return;
    window.location.href = `/cart/increase/${id}/${variantId}`;
  });
});

document.querySelectorAll(".minus").forEach(btn => {
  btn.addEventListener("click", () => {
    if (btn.disabled) return;
    const id = btn.dataset.id;
    const variantId = btn.dataset.variantId;
    if (!id || !variantId) return;
    window.location.href = `/cart/decrease/${id}/${variantId}`;
  });
});
</script>

<%- include('../partials/footer') %>
