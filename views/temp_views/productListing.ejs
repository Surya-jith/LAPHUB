<%- include('../partials/header') %>
<link
  rel="stylesheet"
  href="/css/common.css"
>
<link rel="stylesheet" href="/css/layout.css">
<link rel="stylesheet" href="/css/user/productListing.css">
<% if (typeof error !== "undefined" && error) { %>
  <div class="error-message">
    <%= error %>
  </div>
<% } %>
<section class="product-listing">
<div class="container">

<!-- Top Bar -->
<div class="top-bar">

<!-- Search -->
<div class="search-box">
<form method="GET" action="/products">
<input 
type="text" 
name="search" 
placeholder="Search..." 
value="<%= search || '' %>"
/>

<input type="hidden" name="sort" value="<%= sort || '' %>">
<input type="hidden" name="category" value="<%= selectedCategory || '' %>">
<% if (minPrice) { %>
<input type="hidden" name="minPrice" value="<%= minPrice %>">
<% } %>
<% if (priceRange) { %>
<input type="hidden" name="maxPrice" value="<%= priceRange %>">
<% } %>

<button type="submit">
<i class="fa fa-search"></i>
</button>

</form>
</div>



<!-- Sort -->
<div class="sort-box">

<form method="GET" action="/products">
<input type="hidden" name="search" value="<%= search || '' %>">
<input type="hidden" name="category" value="<%= selectedCategory || '' %>">
<% if (minPrice) { %>
<input type="hidden" name="minPrice" value="<%= minPrice %>">
<% } %>
<% if (priceRange) { %>
<input type="hidden" name="maxPrice" value="<%= priceRange %>">
<% } %>

<span class="sort-label">Sort By:</span>

<select name="sort" onchange="this.form.submit()">

<option value="">Default</option>

<option 
value="price_asc"
<%= sort === 'price_asc' ? 'selected' : '' %>
>
Price ↑
</option>

<option 
value="price_desc"
<%= sort === 'price_desc' ? 'selected' : '' %>
>
Price ↓
</option>

<option 
value="name_asc"
<%= sort === 'name_asc' ? 'selected' : '' %>
>
A – Z
</option>

<option 
value="name_desc"
<%= sort === 'name_desc' ? 'selected' : '' %>
>
Z – A
</option>

</select>

</form>

</div>



<!-- Results -->
<p class="results-count">
<span class="rc-loaded">
<%= products ? products.length : 0 %>
</span> Results
</p>

</div>



<div class="product-layout">

<!-- Sidebar -->
<aside class="sidebar">

<div class="filter-box">
<h4 class="filter-heading">CATEGORY</h4>

<ul class="filter-list">

<li>
<a href="/products?search=<%= encodeURIComponent(search || '') %>&sort=<%= encodeURIComponent(sort || '') %><%= minPrice ? `&minPrice=${encodeURIComponent(minPrice)}` : '' %><%= priceRange ? `&maxPrice=${encodeURIComponent(priceRange)}` : '' %>">All</a>
</li>

<% if(categories && categories.length > 0){ %>

<% categories.forEach(category => { %>

<li>
<a href="/products?category=<%= category._id %>&search=<%= encodeURIComponent(search || '') %>&sort=<%= encodeURIComponent(sort || '') %><%= minPrice ? `&minPrice=${encodeURIComponent(minPrice)}` : '' %><%= priceRange ? `&maxPrice=${encodeURIComponent(priceRange)}` : '' %>">
<%= category.name %>
</a>
</li>

<% }) %>

<% } %>

</ul>

</div>

</aside>



<!-- Products -->
<div class="products">

<% if (!products || products.length === 0) { %>

<div class="empty-state">
<i class="fa fa-inbox"></i>
<p>No products found.</p>
</div>

<% } else { %>

<div class="product-grid">

<% products.forEach((product, i) => { %>

<%
let totalStock = 0

if(product.variants && product.variants.length){
product.variants.forEach(v=>{
totalStock += v.stock
})
}

const isDisabled = 
totalStock === 0 || 
product.isBlocked || 
!product.isListed
%>


<a 
href="<%= isDisabled ? 'javascript:void(0)' : `/product/${product._id}` %>"
class="product-card <%= isDisabled ? 'product-disabled' : '' %>"
style="animation-delay:<%= i * 40 %>ms;"
>

<div class="product-image">

<img
src="<%= product.images && product.images.length ? product.images[0] : '' %>"
alt="<%= product.name %>"
loading="lazy"
/>

<!-- Discount Badge -->
<% if(product.finalOffer > 0){ %>

<span class="discount-badge">
<%= product.finalOffer %>% OFF
</span>

<% } %>

<!-- Out Of Stock Badge -->
<% if(isDisabled){ %>

<span class="out-stock-badge">
Out of Stock
</span>

<% } %>

</div>



<div class="product-info">

<h5 class="product-name">
<%= product.name %>
</h5>

<div class="price">

<span class="new-price">
₹<%= product.finalPrice || product.price %>
</span>

<% if(product.finalOffer > 0){ %>

<span class="old-price">
₹<%= product.price %>
</span>

<% } %>

</div>


<% if(isDisabled){ %>

<span class="out-stock">
Out of Stock
</span>

<% } %>


</div>

</a>

<% }) %>

</div>

<% } %>



<!-- Pagination -->

<% if (totalPages > 1) { %>

<nav class="pagination">

<% for(let i=1;i<=totalPages;i++){ %>

<a
href="?page=<%= i %>&category=<%= selectedCategory || '' %>&sort=<%= encodeURIComponent(sort || '') %>&search=<%= encodeURIComponent(search || '') %><%= minPrice ? `&minPrice=${encodeURIComponent(minPrice)}` : '' %><%= priceRange ? `&maxPrice=${encodeURIComponent(priceRange)}` : '' %>"
class="page-btn <%= currentPage === i ? 'page-btn--active' : '' %>"
>

<%= i %>

</a>

<% } %>

</nav>

<% } %>

</div>

</div>

</div>

</section>

<%- include('../partials/footer') %>

