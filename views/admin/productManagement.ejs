<link rel="stylesheet" href="/css/admin/sidebar.css">
<link rel="stylesheet" href="/css/admin/productManagement.css">

<div class="admin-container">

  <!-- Sidebar -->
  <%- include('./partials/sidebar') %>

  <!-- Main Content -->
  <div class="main-content">

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="error-box"><%= error %></div>
    <% } %>

    <!-- Page Header -->
    <div class="page-header">

      <div>
        <h2>Product</h2>
        <p class="breadcrumb">
          Dashboard > Product List
        </p>
      </div>

      <a href="/admin/add-product" class="btn-add">
        + Add Product
      </a>

    </div>

<!-- Filters + Search -->
<div class="filter-tabs">

  <div class="left-filters">
    <button class="active">
      All Products
    </button>

    <button>
      In Stock
    </button>

    <button>
      Out of Stock
    </button>
  </div>

  <form
    action="/admin/products"
    method="GET"
    class="search-form"
  >
    <input
      type="text"
      name="search"
      placeholder="Search product name..."
      value="<%= search || '' %>"
    >

    <button type="submit">
      Search
    </button>
  </form>

</div>

    <!-- Table -->
    <div class="table-container">

      <table>

        <thead>
          <tr>
            <th>Product</th>
            <th>Category</th>
            <th>Variants</th>
            <th>Stock</th>
            <th>Price</th>
            <th>Status</th>
            <th>Added</th>
            <th>Action</th>
          </tr>
        </thead>

        <tbody>

          <% if (products && products.length > 0) { %>

            <% products.forEach(product => { %>

              <tr>

                <!-- PRODUCT -->
                <td class="product-cell">

                  <div class="product-info">

                    <input type="checkbox">

                    <img
                      src="<%= product.images?.[0] || '/images/no-image.png' %>"
                      class="product-thumb"
                      alt="product"
                    >

                    <span>
                      <%= product.name %>
                    </span>

                  </div>

                </td>

                <!-- CATEGORY -->
                <td>
                  <%= product.category?.name || "-" %>
                </td>

                <!-- VARIANTS -->
                <td>
                  <%= product.variants?.length || 0 %>
                </td>

                <!-- STOCK -->
                <td>

                  <% if (product.isOutOfStock) { %>

                    <span class="status out-stock">
                      Out of Stock
                    </span>

                  <% } else if (product.isLowStock) { %>

                    <span class="status low-stock">
                      Low Stock (<%= product.totalStock %>)
                    </span>

                  <% } else { %>

                    <span class="status in-stock">
                      <%= product.totalStock %>
                    </span>

                  <% } %>

                </td>

                <!-- PRICE -->
                <td>
                  ₹<%= product.price %>
                </td>

                <!-- STATUS -->
                <td>

                  <% if (product.isOutOfStock) { %>

                    <span class="status out-stock">
                      Out of Stock
                    </span>

                  <% } else if (product.isLowStock) { %>

                    <span class="status low-stock">
                      Low Stock
                    </span>

                  <% } else { %>

                    <span class="status in-stock">
                      In Stock
                    </span>

                  <% } %>

                </td>

                <!-- DATE -->
                <td>
                  <%= new Date(product.createdAt).toDateString() %>
                </td>

                <!-- ACTION -->
                <!-- ACTION -->
<td class="actions">

  <a href="/admin/edit-product/<%= product._id %>">
    ✏️
  </a>

  <form
    action="/admin/toggle-product-block/<%= product._id %>"
    method="POST"
    style="display:inline;"
  >
    <button
      type="submit"
      onclick="return confirm('<%= product.isBlocked ? "Unblock" : "Block" %> this product?')"
    >
      <%= product.isBlocked ? "🟢 Unblock" : "🔴 Block" %>
    </button>
  </form>

  <form
    action="/admin/delete-product/<%= product._id %>"
    method="POST"
    style="display:inline;"
  >
    <button
      type="submit"
      onclick="return confirm('Delete product?')"
    >
      🗑️
    </button>
  </form>

</td>
              </tr>

            <% }) %>

          <% } else { %>

            <tr>

              <td colspan="8" style="text-align: center;">
                No Products Found
              </td>

            </tr>

          <% } %>

        </tbody>

      </table>

    </div>

    <!-- Pagination -->
    <div class="pagination">

      <div class="page-btns">

        <% for (let i = 1; i <= totalPages; i++) { %>

          <a
            href="/admin/products?page=<%= i %>&category=<%= selectedCategory || '' %>&search=<%= encodeURIComponent(search || '') %>"
            class="<%= currentPage === i ? 'active' : '' %>"
          >
            <%= i %>
          </a>

        <% } %>

      </div>

    </div>

  </div>

</div>
