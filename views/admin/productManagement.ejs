<link rel="stylesheet" href="/css/admin/sidebar.css">
<link rel="stylesheet" href="/css/admin/productManagement.css">

<div class="admin-container">

  <!-- Sidebar -->
  <%- include('./partials/sidebar') %>

  <!-- Main Content -->
  <div class="main-content">

    <!-- Page Header -->
    <div class="page-header">

      <div>
        <h2>Product</h2>
        <p class="breadcrumb">
          Dashboard > Product List
        </p>
      </div>

      <a href="/admin/add-product" class="btn-add">
        + Add Product
      </a>

    </div>


    <!-- Filters -->
    <div class="filter-tabs">

      <button class="active">All Products</button>
      <button>In Stock</button>
      <button>Out of Stock</button>

    </div>


    <!-- Table -->
    <div class="table-container">

      <table>

        <thead>

          <tr>
            <th>Product</th>
            <th>Category</th>
            <th>Variants</th>
            <th>Stock</th>
            <th>Price</th>
            <th>Status</th>
            <th>Added</th>
            <th>Action</th>
          </tr>

        </thead>

        <tbody>

          <% if(products && products.length > 0){ %>

          <% products.forEach(product => { %>

          <tr>

            <td class="product-cell">

              <div class="product-info">

                <input type="checkbox">

                <img 
                src="<%= product.images?.[0] %>" 
                class="product-thumb"
                alt="product"
                >

                <span>
                  <%= product.name %>
                </span>

              </div>

            </td>

            <td>
              <%= product.category?.name %>
            </td>

            <td>
              <%= product.variants?.length || 0 %>
            </td>

            <td>
              <%= product.totalStock %>
            </td>

            <td>
              ₹<%= product.price %>
            </td>

            <td>

              <% if(product.totalStock > 0){ %>

              <span class="status in-stock">
                In Stock
              </span>

              <% } else { %>

              <span class="status out-stock">
                Out of Stock
              </span>

              <% } %>

            </td>

            <td>
              <%= new Date(product.createdAt).toDateString() %>
            </td>

            <td class="actions">

              <a href="/admin/edit-product/<%= product._id %>">
                ✏️
              </a>

              <form 
              action="/admin/delete-product/<%= product._id %>" 
              method="POST">

              <button onclick="return confirm('Delete product?')">
                🗑️
              </button>

              </form>

            </td>

          </tr>

          <% }) %>

          <% } else { %>

          <tr>

          <td colspan="8" style="text-align:center">
          No Products Found
          </td>

          </tr>

          <% } %>

        </tbody>

      </table>

    </div>


    <!-- Pagination -->

    <div class="pagination">

      <div class="page-btns">

        <% for(let i=1;i<=totalPages;i++){ %>

        <a 
        href="/admin/products?page=<%= i %>&category=<%= selectedCategory || '' %>"
        class="<%= currentPage === i ? 'active' : '' %>">

        <%= i %>

        </a>

        <% } %>

      </div>

    </div>

  </div>

</div>