<link rel="stylesheet" href="/css/admin/sidebar.css">
<link rel="stylesheet" href="/css/admin/category.css">

<div class="admin-container">

  <!-- SIDEBAR -->
  <%- include('./partials/sidebar') %>

  <div class="main-content">

    <div class="page-header">
      <h2>Add Category</h2>
      <a href="/admin/category" class="btn-back">← Back</a>
    </div>

    <div class="form-container">

      <!-- ✅ ADD ID -->
      <form id="categoryForm" action="/admin/add-category" method="POST">

        <!-- CATEGORY NAME -->
        <div class="form-group">
          <label>Category Name</label>
          <input 
            type="text" 
            id="categoryName"
            name="name" 
            placeholder="Enter category name"
          >
          <small class="error-text" id="nameError"></small>
        </div>

        <div class="form-actions">
          <button type="submit" class="btn-save">
            Create Category
          </button>

          <a href="/admin/category" class="btn-cancel">
            Cancel
          </a>
        </div>

      </form>

    </div>

  </div>

</div>


<!-- 🔥 IMPORT GLOBAL VALIDATION -->
<script type="module">
  import { validateCategoryForm } from "/js/validation.js";

  validateCategoryForm("categoryForm", "categoryName", "nameError");
</script>