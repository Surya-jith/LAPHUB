<link rel="stylesheet" href="/css/admin/sidebar.css">
<link rel="stylesheet" href="/css/admin/addProduct.css">

<link href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.css" rel="stylesheet"/>
<script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.js"></script>

<div class="admin-container">
<%- include('./partials/sidebar') %>

<div class="main-content">

<div class="page-header">
<div>
<h2>Add Product</h2>
<p class="breadcrumb">Dashboard > Product List > Add Product</p>
</div>

<div class="header-actions">
<a href="/admin/products" class="btn-cancel">Cancel</a>
<button form="addProductForm" class="btn-add">+ Add Product</button>
</div>
</div>

<form id="addProductForm" method="POST" enctype="multipart/form-data">

<div class="product-layout">

<!-- LEFT -->
<div class="left-section">

<div class="card">
<h4>General Information</h4>

<label>Product Name</label>
<input type="text" id="productName" name="name">
<small id="nameError" class="error-text"></small>

<label>Description</label>
<textarea id="productDescription" name="description"></textarea>
<small id="descError" class="error-text"></small>
</div>

<div class="card">
<h4>Pricing</h4>

<label>Base Price</label>
<input type="number" id="productPrice" name="price">
<small id="priceError" class="error-text"></small>

<label>Discount</label>
<input type="number" name="discount">
</div>

<div class="card">
<h4>General Photo</h4>

<div class="image-upload-grid">

<div class="image-upload-box">
<input type="file" name="images" onchange="previewImage(event,0)">
<img id="preview0" class="preview-img">
</div>

<div class="image-upload-box">
<input type="file" name="images" onchange="previewImage(event,1)">
<img id="preview1" class="preview-img">
</div>

<div class="image-upload-box">
<input type="file" name="images" onchange="previewImage(event,2)">
<img id="preview2" class="preview-img">
</div>

</div>
</div>

</div>

<!-- RIGHT -->
<div class="right-section">

<div class="card">
<h4>Category</h4>
<select id="productCategory" name="category">
<option value="">Select Category</option>
<% categories.forEach(cat=>{ %>
<option value="<%= cat._id %>"><%= cat.name %></option>
<% }) %>
</select>
<small id="categoryError" class="error-text"></small>
</div>

<div class="card">
<h4>Brand</h4>
<select name="brand">
<option value="">Select Brand</option>
<% brands.forEach(b=>{ %>
<option value="<%= b._id %>"><%= b.name %></option>
<% }) %>
</select>
</div>

<div class="card">
<h4>Variants</h4>

<div id="variantContainer">

<div class="variant-row">

<div class="variant-fields">
<input name="color[]" placeholder="Color">
<input name="ram[]" placeholder="RAM">
<input name="rom[]" placeholder="ROM">

<div class="variant-field">
<input name="stock[]" placeholder="Stock">
<small class="error-text stock-error"></small>
</div>

<div class="variant-field">
<input name="variantPrice[]" placeholder="Price">
<small class="error-text price-error"></small>
</div>
</div>

<div class="variant-image-box">
<label>Variant Image</label>
<input type="file" name="variantImages" onchange="previewVariantImage(event,this)">
<img class="variant-preview" style="display:none; width:80px;">
</div>

<button type="button" onclick="removeVariant(this)">Remove</button>

</div>
</div>

<button type="button" onclick="addVariant()">+ Add Variant</button>

</div>

</div>

</div>

<button>Add</button>
</form>

</div>
</div>

<!-- 🔥 CROP MODAL (FIXED) -->
<div id="cropModal" class="crop-modal">

  <div class="crop-container">

    <div class="crop-header">
      <h3>Crop Image</h3>
      <button class="close-btn" onclick="closeCrop()">×</button>
    </div>

    <div class="crop-body">
      <img id="cropImage">
    </div>

    <div class="crop-footer">
      <button class="btn-cancel" onclick="closeCrop()">Cancel</button>
      <button class="btn-crop" onclick="cropImage()">Crop & Save</button>
    </div>

  </div>

</div>

<script>

let cropper;
let currentInput;
let currentIndex;

function previewImage(e,i){
const file=e.target.files[0];
if(!file) return;

currentInput=e.target;
currentIndex=i;

const reader=new FileReader();
reader.onload=()=>{
document.getElementById("cropModal").style.display="flex";
document.getElementById("cropImage").src=reader.result;

if(cropper) cropper.destroy();
cropper=new Cropper(document.getElementById("cropImage"),{aspectRatio:1});
};
reader.readAsDataURL(file);
}

function previewVariantImage(e,input){
const file=e.target.files[0];
if(!file) return;

currentInput=input;
currentIndex=null;

const reader=new FileReader();
reader.onload=()=>{
document.getElementById("cropModal").style.display="flex";
document.getElementById("cropImage").src=reader.result;

if(cropper) cropper.destroy();
cropper=new Cropper(document.getElementById("cropImage"),{aspectRatio:1});
};
reader.readAsDataURL(file);
}

function cropImage(){
const canvas=cropper.getCroppedCanvas();

canvas.toBlob(blob=>{
const file=new File([blob],"crop.jpg");
const dt=new DataTransfer();
dt.items.add(file);
currentInput.files=dt.files;

const reader=new FileReader();
reader.onload=()=>{
if(currentIndex!==null){
document.getElementById(`preview${currentIndex}`).src=reader.result;
}else{
const preview=currentInput.closest(".variant-image-box").querySelector(".variant-preview");
preview.src=reader.result;
preview.style.display="block";
}
};
reader.readAsDataURL(file);

closeCrop();
});
}

function closeCrop(){
document.getElementById("cropModal").style.display="none";
}

function addVariant(){
document.getElementById("variantContainer").insertAdjacentHTML("beforeend",`
<div class="variant-row">
<input name="color[]" placeholder="Color">
<input name="ram[]" placeholder="RAM">
<input name="rom[]" placeholder="ROM">
<input name="stock[]" placeholder="Stock">
<input name="variantPrice[]" placeholder="Price">

<div class="variant-image-box">
<input type="file" name="variantImages" onchange="previewVariantImage(event,this)">
<img class="variant-preview" style="display:none;width:80px;">
</div>

<button type="button" onclick="removeVariant(this)">Remove</button>
</div>
`);
}

function removeVariant(btn){
btn.closest(".variant-row").remove();
}

</script>