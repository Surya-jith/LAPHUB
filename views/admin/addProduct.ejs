<link rel="stylesheet" href="/css/admin/sidebar.css">
<link rel="stylesheet" href="/css/admin/addProduct.css">

<link 
href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.css" 
rel="stylesheet"
/>

<script 
src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.js">
</script>

<div class="admin-container">

<%- include('./partials/sidebar') %>

<div class="main-content">

<div class="page-header">
<div>
<h2>Add Product</h2>
<p class="breadcrumb">
Dashboard > Product List > Add Product
</p>
</div>

<div class="header-actions">
<a href="/admin/products" class="btn-cancel">
Cancel
</a>

<button form="addProductForm" class="btn-add">
+ Add Product
</button>
</div>

</div>


<% if(typeof error !== 'undefined'){ %>
<div class="alert-error">
<%= error %>
</div>
<% } %>


<form id="addProductForm" method="POST" enctype="multipart/form-data">

<div class="product-layout">


<!-- LEFT -->
<div class="left-section">

<!-- General -->
<div class="card">

<h4>General Information</h4>

<label>Product Name</label>
<input type="text" name="name" value="<%= formData?.name || '' %>">

<label>Description</label>
<textarea name="description"><%= formData?.description || '' %></textarea>

</div>


<!-- Pricing -->
<div class="card">

<h4>Pricing</h4>

<label>Base Price</label>
<input type="number" name="price">

<label>Discount</label>
<input type="number" name="discount">

</div>


<!-- Images -->
<div class="card">

<h4>General Photo</h4>

<div class="image-upload-grid">

<div class="image-upload-box">
<input type="file" name="images" onchange="previewImage(event,0)">
<img id="preview0" class="preview-img">
</div>

<div class="image-upload-box">
<input type="file" name="images" onchange="previewImage(event,1)">
<img id="preview1" class="preview-img">
</div>

<div class="image-upload-box">
<input type="file" name="images" onchange="previewImage(event,2)">
<img id="preview2" class="preview-img">
</div>

</div>

</div>

</div>


<!-- RIGHT -->
<div class="right-section">

<div class="card">

<h4>Category</h4>

<select name="category">

<option value="">Select Category</option>

<% categories.forEach(cat=>{ %>

<option value="<%= cat._id %>"><%= cat.name %></option>

<% }) %>

</select>

</div>


<div class="card">

<h4>Brand</h4>

<select name="brand">

<option value="">Select Brand</option>

<% brands.forEach(b=>{ %>

<option value="<%= b._id %>"><%= b.name %></option>

<% }) %>

</select>

</div>


<div class="card">

<h4>Variants</h4>

<div id="variantContainer">

<div class="variant-row">

<div class="variant-fields">

<input name="color[]" placeholder="Color">
<input name="ram[]" placeholder="RAM">
<input name="rom[]" placeholder="ROM">
<input name="stock[]" placeholder="Stock">
<input name="variantPrice[]" placeholder="Price">

</div>

<div class="variant-image-box">

<label>Variant Image</label>
<input type="file" name="variantImages">

</div>

<div class="variant-actions">

<button 
type="button" 
class="variant-remove"
onclick="removeVariant(this)"
>
Remove
</button>

</div>

</div>

</div>

<button 
type="button" 
class="btn-add-variant"
onclick="addVariant()"
>
+ Add Variant
</button>

</div>

</div>

</div>

<div class="submit-btn">
<button>Add</button>
</div>

</form>

</div>

</div>


<!-- Crop Modal -->
<div id="cropModal" class="crop-modal">
<div class="crop-container">
<img id="cropImage">
<div class="crop-actions">
<button onclick="cropImage()">Crop</button>
<button onclick="closeCrop()">Cancel</button>
</div>
</div>
</div>


<script>

let cropper
let currentInput
let currentIndex

function previewImage(event,index){

const file = event.target.files[0]

if(!file) return

const allowed = ["image/jpeg","image/png","image/webp"]

if(!allowed.includes(file.type)){
alert("Only JPG PNG WEBP allowed")
event.target.value=""
return
}

currentInput = event.target
currentIndex = index

const reader = new FileReader()

reader.onload = function(){

document.getElementById("cropModal").style.display="flex"

const image = document.getElementById("cropImage")

image.src = reader.result

if(cropper){
cropper.destroy()
}

cropper = new Cropper(image,{
aspectRatio:1,
viewMode:1
})

}

reader.readAsDataURL(file)

}



function cropImage(){

const canvas = cropper.getCroppedCanvas()

canvas.toBlob(function(blob){

const file = new File([blob],"cropped.jpg")

const dt = new DataTransfer()

dt.items.add(file)

currentInput.files = dt.files

const reader = new FileReader()

reader.onload = function(){

document.getElementById(`preview${currentIndex}`).src = reader.result

}

reader.readAsDataURL(file)

closeCrop()

})

}


function closeCrop(){

document.getElementById("cropModal").style.display="none"

}



function addVariant(){

const html=`

<div class="variant-row">

<div class="variant-fields">

<input name="color[]" placeholder="Color">
<input name="ram[]" placeholder="RAM">
<input name="rom[]" placeholder="ROM">
<input name="stock[]" placeholder="Stock">
<input name="variantPrice[]" placeholder="Price">

</div>

<div class="variant-image-box">

<label>Variant Image</label>
<input type="file" name="variantImages">

</div>

<div class="variant-actions">

<button 
type="button"
class="variant-remove"
onclick="removeVariant(this)"
>
Remove
</button>

</div>

</div>

`

document
.getElementById("variantContainer")
.insertAdjacentHTML("beforeend",html)

}


function removeVariant(btn){
btn.closest(".variant-row").remove()
}

</script>