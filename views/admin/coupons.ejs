<link
  rel="stylesheet"
  href="/css/admin/sidebar.css"
/>

<link
  rel="stylesheet"
  href="/css/admin/coupons.css"
/>

<div class="admin-container">

  <%- include('./partials/sidebar') %>

  <div class="main-content">

    <!-- HEADER -->
    <div class="page-header">

      <h2>
        Coupon Management
      </h2>

      <a
        href="/admin/add-coupon"
        class="btn-add"
      >
        + Add Coupon
      </a>

    </div>

    <!-- TABLE -->
    <div class="table-container">

      <table>

        <thead>

          <tr>

            <th>Code</th>

            <th>Type</th>

            <th>Discount</th>

            <th>Min Amount</th>

            <th>Expiry</th>

            <th>Status</th>

            <th>Actions</th>

          </tr>

        </thead>

        <tbody>

          <% coupons.forEach(coupon => { %>

            <tr>

              <td>
                <%= coupon.code %>
              </td>

              <td>
                <%= coupon.discountType %>
              </td>

              <td>

                <% if (
                  coupon.discountType
                  === "percentage"
                ) { %>

                  <%= coupon.discountValue %>%

                <% } else { %>

                  ₹<%= coupon.discountValue %>

                <% } %>

              </td>

              <td>
                ₹<%= coupon.minimumAmount %>
              </td>

              <td>

                <%= new Date(
                  coupon.expiryDate
                ).toLocaleDateString() %>

              </td>

              <td>

                <span
                  class="
                    status
                    <%= coupon.isActive
                      ? 'active'
                      : 'inactive'
                    %>
                  "
                >

                  <%= coupon.isActive
                    ? 'Active'
                    : 'Inactive'
                  %>

                </span>

              </td>

              <td class="actions">

                <!-- TOGGLE -->
                <form
                  action="/admin/toggle-coupon/<%= coupon._id %>"
                  method="POST"
                >

                  <button
                    type="submit"
                    class="btn-toggle"
                  >

                    <%= coupon.isActive
                      ? 'Disable'
                      : 'Enable'
                    %>

                  </button>

                </form>

                <!-- DELETE -->
                <form
                  action="/admin/delete-coupon/<%= coupon._id %>"
                  method="POST"
                >

                  <button
                    type="submit"
                    class="btn-delete"
                  >
                    Delete
                  </button>

                </form>

              </td>

            </tr>

          <% }) %>

        </tbody>

      </table>

    </div>

  </div>

</div>