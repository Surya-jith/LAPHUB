<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | LapHUB</title>
  <link rel="stylesheet" href="/css/common.css">
  <link rel="stylesheet" href="/css/responsive.css">
</head>
<body>
  <main class="app-error-page">
    <section class="app-error-card">
      <p class="app-error-code"><%= statusCode %></p>
      <h1><%= title %></h1>
      <p><%= message %></p>
      <a href="/" class="app-error-action">Return Home</a>
    </section>
  </main>
</body>
</html>
